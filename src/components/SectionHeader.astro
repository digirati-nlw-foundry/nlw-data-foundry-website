---
interface Props {
  eyebrow?: string;
  eyebrowColor?: string;
  heading: string;
  subtext?: string;
  level?: 1 | 2;
}

const {
  eyebrow,
  eyebrowColor = "text-blue-700",
  heading,
  subtext,
  level = 2,
} = Astro.props;
---

<div>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-widest ${eyebrowColor} mb-2`}>{eyebrow}</p>
  )}
  {level === 1
    ? <h1 class="text-4xl font-bold text-gray-900 mb-3">{heading}</h1>
    : <h2 class="text-2xl font-bold text-gray-900 mb-3">{heading}</h2>
  }
  {subtext && (
    <p class="text-lg text-gray-600 max-w-2xl">{subtext}</p>
  )}
</div>
