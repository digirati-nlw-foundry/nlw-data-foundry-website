---
import type { Locale, LocalizedString } from "../lib/i18n";
import { getLocalizedString } from "../lib/i18n";

interface Props {
  locale: Locale;
  href: string;
  title: LocalizedString;
  summary: LocalizedString;
  eyebrow?: LocalizedString;
  accent?: string;
  tags?: LocalizedString[];
}

const {
  locale,
  href,
  title,
  summary,
  eyebrow,
  accent = "var(--default-accent)",
  tags = [],
} = Astro.props;
---

<article class="bg-gray-100 p-6 flex flex-col rounded" style={`--accent:${accent};`}>
  {eyebrow && <p class="text-sm text-black/60 uppercase">{getLocalizedString(eyebrow, locale)}</p>}
  <div class="listing-card__art" aria-hidden="true"></div>
  <div class="flex-1">
    <h3 class="text-xl hover:underline font-bold text-(--accent)"><a href={href}>{getLocalizedString(title, locale)}</a></h3>
    <p class="mb-4">{getLocalizedString(summary, locale)}</p>
  </div>

  {
    tags.length > 0 && (
      <ul class="flex gap-2 mb-3" aria-label={locale === "en" ? "Tags" : "Tagiau"}>
        {tags.map((tag) => (
          <li class="bg-(--accent)/10 text-(--accent) px-2 py-1 rounded-sm">{getLocalizedString(tag, locale)}</li>
        ))}
      </ul>
    )
  }

  <div>
    <a class="bg-(--accent) hover:bg-(--accent)/90 px-3 py-2 rounded-sm text-white inline-flex" href={href}>
      {locale === "en" ? "Read more" : "Darllen mwy"}
    </a>
  </div>
</article>
