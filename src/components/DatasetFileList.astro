---
import type { SiteDataCardFileGroup } from "../lib/data-cards";
import { contentTypeLabel, formatBytes } from "../lib/file-utils";
import {
  formatDateRelative,
  formatDateTimeShort,
  type Locale,
} from "../lib/i18n";

interface Props {
  locale: Locale;
  accent: string;
  files: {
    active: SiteDataCardFileGroup[];
    archived: SiteDataCardFileGroup[];
  };
}

const { locale, accent, files } = Astro.props;

const hasActive = files.active.length > 0;
const hasArchived = files.archived.length > 0;
---

<section
  class="mt-10 rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden"
  style={`--accent: ${accent};`}
>
  <!-- Header -->
  <div class="px-6 pt-6 pb-5 border-b border-gray-100">
    <h2 class="text-xl font-bold text-gray-900">
      {locale === "en" ? "Files & versions" : "Ffeiliau a fersiynau"}
    </h2>
  </div>

  <div class="divide-y divide-gray-100">
    <!-- Active files -->
    {hasActive && files.active.map((group) => (
      <div>
        <!-- Version header row -->
        <div class="flex items-center gap-3 px-6 py-3 bg-gray-50 border-b border-gray-100">
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24">
              <!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE -->
              <path fill="currentColor" d="M6.5 20q-2.275 0-3.887-1.575T1 14.575q0-1.95 1.175-3.475T5.25 9.15q.575-2.025 2.138-3.4T11 4.075v8.075L9.4 10.6L8 12l4 4l4-4l-1.4-1.4l-1.6 1.55V4.075q2.575.35 4.288 2.313T19 11q1.725.2 2.863 1.488T23 15.5q0 1.875-1.312 3.188T18.5 20z"/>
            </svg>
            {locale === "en" ? `Version ${group.version}` : `Fersiwn ${group.version}`}
          </span>
          <span class="ml-auto inline-flex items-center rounded-full bg-(--accent)/10 px-2 py-0.5 text-xs font-medium text-(--accent)">
            {locale === "en"
              ? `${group.files.length} file${group.files.length === 1 ? "" : "s"}`
              : `${group.files.length} ffeil`}
          </span>
          <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
            {locale === "en" ? "Active" : "Gweithredol"}
          </span>
        </div>

        <!-- File rows -->
        <ul class="divide-y divide-gray-100">
          {group.files.map((file) => (
            <li class="flex items-center gap-4 px-6 py-4 hover:bg-gray-50/60 transition-colors">
              <!-- File icon -->
              <div class="shrink-0 w-8 h-8 rounded-lg bg-(--accent)/10 flex items-center justify-center" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-(--accent)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                  <polyline points="14 2 14 8 20 8" />
                </svg>
              </div>

              <!-- Name + meta -->
              <div class="min-w-0 flex-1">
                <p class="text-sm font-semibold text-gray-900 truncate" title={file.fileName}>
                  {file.fileName}
                </p>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-0.5">
                  {file.contentType && (
                    <span class="text-xs text-gray-400 font-mono">
                      {contentTypeLabel(file.contentType)}
                    </span>
                  )}
                  {typeof file.fileSizeBytes === "number" && (
                    <span class="text-xs text-gray-400">
                      {formatBytes(file.fileSizeBytes)}
                    </span>
                  )}
                  {file.ingestedAt && (
                    <span
                      class="text-xs text-gray-400"
                      title={formatDateTimeShort(file.ingestedAt, locale)}
                    >
                      {formatDateRelative(file.ingestedAt, locale)}
                    </span>
                  )}
                </div>
              </div>

              <!-- Download button -->
              {file.apiLink && (
                <a
                  href={file.apiLink}
                  class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-(--accent) px-3 py-1.5 text-xs font-semibold text-(--accent) hover:bg-(--accent) hover:text-white transition-colors"
                  aria-label={`${locale === "en" ? "Download" : "Lawrlwytho"} ${file.fileName}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="7 10 12 15 17 10" />
                    <line x1="12" y1="15" x2="12" y2="3" />
                  </svg>
                  {locale === "en" ? "Download" : "Lawrlwytho"}
                </a>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}

    <!-- Archived files -->
    {hasArchived && (
      <details class="group">
        <summary class="flex cursor-pointer items-center gap-3 px-6 py-3 bg-gray-50 hover:bg-gray-100 transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span class="text-xs font-semibold text-gray-500">
            {locale === "en"
              ? `${files.archived.reduce((n, g) => n + g.files.length, 0)} archived file${files.archived.reduce((n, g) => n + g.files.length, 0) === 1 ? "" : "s"}`
              : `${files.archived.reduce((n, g) => n + g.files.length, 0)} ffeil archifedig`}
          </span>
        </summary>

        <div class="divide-y divide-gray-100">
          {files.archived.map((group) => (
            <div>
              <!-- Version header row -->
              <div class="flex items-center gap-3 px-6 py-3 bg-gray-50/50 border-b border-gray-100">
                <span class="text-xs font-semibold text-gray-500">
                  {locale === "en" ? `Version ${group.version}` : `Fersiwn ${group.version}`}
                </span>
                <span class="ml-auto inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">
                  {locale === "en"
                    ? `${group.files.length} file${group.files.length === 1 ? "" : "s"}`
                    : `${group.files.length} ffeil`}
                </span>
                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500 ring-1 ring-inset ring-gray-400/20">
                  {locale === "en" ? "Archived" : "Archifedig"}
                </span>
              </div>

              <!-- File rows -->
              <ul class="divide-y divide-gray-100">
                {group.files.map((file) => (
                  <li class="flex items-center gap-4 px-6 py-4 opacity-70 hover:opacity-100 transition-opacity">
                    <!-- File icon -->
                    <div class="shrink-0 w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                      </svg>
                    </div>

                    <!-- Name + meta -->
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-gray-600 truncate" title={file.fileName}>
                        {file.fileName}
                      </p>
                      <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-0.5">
                        {file.contentType && (
                          <span class="text-xs text-gray-400 font-mono">
                            {contentTypeLabel(file.contentType)}
                          </span>
                        )}
                        {typeof file.fileSizeBytes === "number" && (
                          <span class="text-xs text-gray-400">
                            {formatBytes(file.fileSizeBytes)}
                          </span>
                        )}
                        {file.ingestedAt && (
                          <span
                            class="text-xs text-gray-400"
                            title={formatDateTimeShort(file.ingestedAt, locale)}
                          >
                            {formatDateRelative(file.ingestedAt, locale)}
                          </span>
                        )}
                      </div>
                    </div>

                    <!-- Download button (muted for archived) -->
                    {file.apiLink && (
                      <a
                        href={file.apiLink}
                        class="shrink-0 inline-flex items-center gap-1.5 rounded-lg border border-gray-300 px-3 py-1.5 text-xs font-semibold text-gray-500 hover:border-gray-400 hover:text-gray-700 transition-colors"
                        aria-label={`${locale === "en" ? "Download" : "Lawrlwytho"} ${file.fileName}`}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                          <polyline points="7 10 12 15 17 10" />
                          <line x1="12" y1="15" x2="12" y2="3" />
                        </svg>
                        {locale === "en" ? "Download" : "Lawrlwytho"}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </details>
    )}
  </div>
</section>
