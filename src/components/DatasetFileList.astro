---
import type { SiteDataCardFileGroup } from "../lib/data-cards";
import { formatDateTime, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
  accent: string;
  files: {
    active: SiteDataCardFileGroup[];
    archived: SiteDataCardFileGroup[];
  };
}

const { locale, accent, files } = Astro.props;

function formatBytes(value?: number) {
  if (typeof value !== "number" || Number.isNaN(value)) {
    return undefined;
  }

  if (value < 1024) {
    return `${value} B`;
  }

  const units = ["KB", "MB", "GB", "TB"];
  let size = value / 1024;
  let unitIndex = 0;

  while (size >= 1024 && unitIndex < units.length - 1) {
    size /= 1024;
    unitIndex += 1;
  }

  const precision = size >= 100 ? 0 : size >= 10 ? 1 : 2;

  return `${size.toFixed(precision)} ${units[unitIndex]}`;
}
---

<section class="mt-10 rounded-xl border border-gray-200 bg-white p-6 shadow-sm" style={`--accent: ${accent};`}>
  <p class="text-xs font-semibold uppercase tracking-widest text-(--accent) mb-1">
    {locale === "en" ? "Dataset files" : "Ffeiliau set ddata"}
  </p>
  <h2 class="text-2xl font-bold text-gray-900 mb-2">
    {locale === "en" ? "Files and versions" : "Ffeiliau a fersiynau"}
  </h2>
  <p class="text-sm text-gray-600 mb-6">
    {locale === "en"
      ? "The backend-generated file manifest is shown here so users can inspect each available version and download link."
      : "Dangosir y maniffest ffeiliau a gynhyrchir gan y backend yma fel y gall defnyddwyr archwilio pob fersiwn a dolen lawrlwytho sydd ar gael."}
  </p>

  <div class="space-y-8">
    {files.active.length > 0 && (
      <section>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">
          {locale === "en" ? "Active files" : "Ffeiliau gweithredol"}
        </h3>
        <div class="space-y-5">
          {files.active.map((group) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <div class="flex items-center justify-between gap-3 mb-4">
                <h4 class="text-base font-semibold text-gray-900">
                  {locale === "en"
                    ? `Version ${group.version}`
                    : `Fersiwn ${group.version}`}
                </h4>
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500">
                  {locale === "en"
                    ? `${group.files.length} file${group.files.length === 1 ? "" : "s"}`
                    : `${group.files.length} ffeil`}
                </p>
              </div>

              <ul class="space-y-4">
                {group.files.map((file) => (
                  <li class="rounded-lg border border-gray-200 bg-white p-4">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                      <div class="min-w-0">
                        <p class="text-base font-semibold text-gray-900 break-all">
                          {file.fileName}
                        </p>
                        <dl class="mt-3 grid grid-cols-1 gap-2 text-sm text-gray-700">
                          {file.contentType && (
                            <div>
                              <dt class="font-medium text-gray-500">
                                {locale === "en" ? "Content type" : "Math o gynnwys"}
                              </dt>
                              <dd>{file.contentType}</dd>
                            </div>
                          )}

                          {typeof file.fileSizeBytes === "number" && (
                            <div>
                              <dt class="font-medium text-gray-500">
                                {locale === "en" ? "Size" : "Maint"}
                              </dt>
                              <dd>{formatBytes(file.fileSizeBytes)}</dd>
                            </div>
                          )}

                          {file.ingestedAt && (
                            <div>
                              <dt class="font-medium text-gray-500">
                                {locale === "en" ? "Ingested" : "Mewnforiwyd"}
                              </dt>
                              <dd>{formatDateTime(file.ingestedAt, locale)}</dd>
                            </div>
                          )}

                          {file.apiLink && (
                            <div>
                              <dt class="font-medium text-gray-500">
                                {locale === "en" ? "Download" : "Lawrlwytho"}
                              </dt>
                              <dd>
                                <a
                                  href={file.apiLink}
                                  class="inline-flex items-center text-(--accent) hover:underline"
                                >
                                  {locale === "en"
                                    ? "Download file"
                                    : "Lawrlwytho'r ffeil"}
                                </a>
                              </dd>
                            </div>
                          )}

                          <div>
                            <dt class="font-medium text-gray-500">
                              {locale === "en" ? "Storage path" : "Llwybr storio"}
                            </dt>
                            <dd class="break-all">
                              <code class="rounded bg-gray-100 px-1 py-0.5 text-xs text-gray-700">
                                {file.fileUrl}
                              </code>
                            </dd>
                          </div>

                          {file.sha256 && (
                            <div>
                              <dt class="font-medium text-gray-500">SHA-256</dt>
                              <dd class="break-all">
                                <code class="rounded bg-gray-100 px-1 py-0.5 text-xs text-gray-700">
                                  {file.sha256}
                                </code>
                              </dd>
                            </div>
                          )}
                        </dl>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    {files.archived.length > 0 && (
      <section>
        <h3 class="text-lg font-semibold text-gray-900 mb-4">
          {locale === "en" ? "Archived files" : "Ffeiliau archifedig"}
        </h3>
        <div class="space-y-5">
          {files.archived.map((group) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <div class="flex items-center justify-between gap-3 mb-4">
                <h4 class="text-base font-semibold text-gray-900">
                  {locale === "en"
                    ? `Version ${group.version}`
                    : `Fersiwn ${group.version}`}
                </h4>
                <p class="text-xs font-medium uppercase tracking-wide text-gray-500">
                  {locale === "en"
                    ? `${group.files.length} file${group.files.length === 1 ? "" : "s"}`
                    : `${group.files.length} ffeil`}
                </p>
              </div>

              <ul class="space-y-4">
                {group.files.map((file) => (
                  <li class="rounded-lg border border-gray-200 bg-white p-4">
                    <p class="text-base font-semibold text-gray-900 break-all">
                      {file.fileName}
                    </p>
                    <dl class="mt-3 grid grid-cols-1 gap-2 text-sm text-gray-700">
                      {file.contentType && (
                        <div>
                          <dt class="font-medium text-gray-500">
                            {locale === "en" ? "Content type" : "Math o gynnwys"}
                          </dt>
                          <dd>{file.contentType}</dd>
                        </div>
                      )}

                      {typeof file.fileSizeBytes === "number" && (
                        <div>
                          <dt class="font-medium text-gray-500">
                            {locale === "en" ? "Size" : "Maint"}
                          </dt>
                          <dd>{formatBytes(file.fileSizeBytes)}</dd>
                        </div>
                      )}

                      {file.ingestedAt && (
                        <div>
                          <dt class="font-medium text-gray-500">
                            {locale === "en" ? "Ingested" : "Mewnforiwyd"}
                          </dt>
                          <dd>{formatDateTime(file.ingestedAt, locale)}</dd>
                        </div>
                      )}

                      <div>
                        <dt class="font-medium text-gray-500">
                          {locale === "en" ? "Storage path" : "Llwybr storio"}
                        </dt>
                        <dd class="break-all">
                          <code class="rounded bg-gray-100 px-1 py-0.5 text-xs text-gray-700">
                            {file.fileUrl}
                          </code>
                        </dd>
                      </div>

                      {file.sha256 && (
                        <div>
                          <dt class="font-medium text-gray-500">SHA-256</dt>
                          <dd class="break-all">
                            <code class="rounded bg-gray-100 px-1 py-0.5 text-xs text-gray-700">
                              {file.sha256}
                            </code>
                          </dd>
                        </div>
                      )}
                    </dl>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</section>
